# Copy to .env and fill in as needed. The app runs fully WITHOUT any key (stub provider).
#
# Leave ANTHROPIC_API_KEY empty (and/or LLM_PROVIDER=stub) to run on deterministic canned data.
# Set a real key AND LLM_PROVIDER=anthropic to switch to real Claude + the ReAct research agent.
ANTHROPIC_API_KEY=
LLM_PROVIDER=stub
MODEL=claude-sonnet-5
RESEARCH_MODE=mock

# SQLite checkpoint file (enables interrupt()/resume across HTTP requests). Gitignored.
CHECKPOINT_DB=checkpoints.sqlite

# Comma-separated origins allowed by CORS (the Next.js dev server).
CORS_ORIGINS=http://localhost:3000
